{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Wirescript",
  "scopeName": "source.wirescript",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#asset-reference" },
    { "include": "#numbers" },
    { "include": "#annotations" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#builtins" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#function-call" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.wirescript",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.wirescript",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.wirescript",
              "match": "\\\\[nrt\"\\\\$0]"
            },
            {
              "name": "meta.embedded.expression.wirescript",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.definition.interpolation.begin.wirescript" } },
              "endCaptures": { "0": { "name": "punctuation.definition.interpolation.end.wirescript" } },
              "patterns": [{ "include": "source.wirescript" }]
            }
          ]
        },
        {
          "name": "string.quoted.single.wirescript",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.wirescript",
              "match": "\\\\[nrt'\\\\$]"
            },
            {
              "name": "meta.embedded.expression.wirescript",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.definition.interpolation.begin.wirescript" } },
              "endCaptures": { "0": { "name": "punctuation.definition.interpolation.end.wirescript" } },
              "patterns": [{ "include": "source.wirescript" }]
            }
          ]
        }
      ]
    },
    "asset-reference": {
      "patterns": [
        {
          "comment": "Prefab file reference: $./rel/path.brz or $/abs/path.brz",
          "name": "meta.reference.prefab.wirescript",
          "match": "(\\$)(\\.?/[A-Za-z0-9_./-]+)",
          "captures": {
            "1": { "name": "punctuation.definition.asset.wirescript" },
            "2": { "name": "string.other.path.prefab.wirescript" }
          }
        },
        {
          "comment": "External asset reference: $AssetType/AssetName",
          "name": "meta.reference.asset.wirescript",
          "match": "(\\$)([A-Za-z_][A-Za-z0-9_.-]*)(/)([A-Za-z0-9_./-]+)",
          "captures": {
            "1": { "name": "punctuation.definition.asset.wirescript" },
            "2": { "name": "entity.name.namespace.asset.wirescript" },
            "3": { "name": "punctuation.separator.asset.wirescript" },
            "4": { "name": "entity.name.asset.wirescript" }
          }
        },
        {
          "comment": "Bare asset reference without a slash: $AssetName",
          "name": "meta.reference.asset.wirescript",
          "match": "(\\$)([A-Za-z_][A-Za-z0-9_.-]*)",
          "captures": {
            "1": { "name": "punctuation.definition.asset.wirescript" },
            "2": { "name": "entity.name.asset.wirescript" }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.wirescript",
          "match": "\\b\\d+\\.\\d*\\b"
        },
        {
          "name": "constant.numeric.integer.wirescript",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "storage.modifier.annotation.wirescript",
          "match": "@(left|right|top|bottom|label|closed)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.wirescript",
          "match": "\\b(if|else|then|match|on|return|emit|await|from|as)\\b"
        },
        {
          "name": "keyword.declaration.wirescript",
          "match": "\\b(var|static|array|buffer|let|fn|chip|mod|in|out|open|ref|import|type)\\b"
        },
        {
          "name": "storage.modifier.wirescript",
          "match": "\\*(?=\\s*[a-zA-Z])"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.wirescript",
          "match": "\\b(int|float|bool|string|entity|controller|character|vector|rotator|color|exec|brick|prefab)\\b"
        },
        {
          "name": "entity.name.type.wirescript",
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.wirescript",
          "match": "\\b(sin|cos|asin|acos|atan|atan2|sinh|cosh|tanh|asinh|acosh|atanh|exp|ln|sign|round|Deg2Rad|Rad2Deg|min|max|BitCount|MakeColor|Vec|Dot|Cross|Normalize|Magnitude|MagnitudeSq|Distance|DistanceSq|ScaleVec|RotToDir|DisplayText|ControllerOf|CharacterOf|AimOrigin|AimDirection|InputReader|Random|Fmt|SetLocation|SetRotation|SetLocationRotation|AddLocationRotation|Teleport|RelativeTeleport|SetVelocity|AddVelocity|SetLinearVelocity|SetAngularVelocity|SetGravityDirection|SetLeaderboard|IncLeaderboard|GetLeaderboard|GetTeam|GetLocation|GetRotation|GetLocationRotation|GetLinearVelocity|GetAngularVelocity|GetVelocity|SpawnPrefab|Sweep)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.wirescript",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.wirescript",
          "match": "(&&|\\|\\||==|!=|<=|>=|\\.\\.|\\.prev|\\.Value|->|[+\\-*/<>!&|^~%]|=)"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "entity.name.function.wirescript",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": { "1": { "name": "entity.name.function.wirescript" } }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.wirescript",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
