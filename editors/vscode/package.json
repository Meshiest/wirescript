{
  "name": "wirescript",
  "displayName": "Wirescript",
  "description": "Language support for Brickadia Wirescript (.ws)",
  "version": "0.1.0",
  "publisher": "brickadia-community",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:wirescript"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "wirescript",
        "aliases": [
          "Wirescript",
          "ws"
        ],
        "extensions": [
          ".ws"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "wirescript",
        "scopeName": "source.wirescript",
        "path": "./syntaxes/wirescript.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "wirescript.compileAndCopy",
        "title": "Wirescript: Compile and Copy Path"
      }
    ],
    "keybindings": [
      {
        "command": "wirescript.compileAndCopy",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "editorLangId == wirescript"
      }
    ],
    "configuration": {
      "title": "Wirescript",
      "properties": {
        "wirescript.lspPath": {
          "type": "string",
          "default": "",
          "description": "Path to wirescript-lsp binary. Leave empty to use the bundled one."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p ."
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "prettier": "^3.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  }
}
